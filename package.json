{
  "name": "election-process-education",
  "version": "1.0.0",
  "description": "AI-powered Election Process Education Assistant using Google Gemini - Helps users understand the election process, timelines, and steps interactively",
  "main": "server.js",
  "scripts": {
    "start": "npm run build && node server.js",
    "dev": "node server.js",
    "test": "npm run build && npx jest --coverage --forceExit",
    "test:ci": "npm run build && npx jest --ci --coverage --forceExit",
    "lint": "npx eslint .",
    "build": "npx cleancss -o public/css/styles.min.css public/css/styles.css && npx uglifyjs public/js/app.js -o public/js/app.min.js -c -m",
    "docker:build": "docker build -t election-education .",
    "docker:run": "docker run -p 8080:8080 election-education"
  },
  "keywords": [
    "election",
    "education",
    "gemini",
    "google-cloud",
    "cloud-run",
    "ai-assistant",
    "civic-education",
    "voter-education"
  ],
  "author": "Election Education Team",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.24.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "helmet": "^8.0.0",
    "hpp": "^0.2.3",
    "validator": "^13.15.35",
    "winston": "^3.14.0",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "clean-css-cli": "^5.6.3",
    "eslint": "^10.3.0",
    "eslint-plugin-node": "^11.1.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "uglify-js": "^3.19.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
